    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
            -webkit-user-select: none;
            user-select: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft YaHei', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0;
            margin: 0;
        }

        .container {
            width: 100%;
            height: 100vh;
            max-width: 100%;
            background: rgba(255, 255, 255, 0.95);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        @media (min-width: 768px) {
            .container {
                max-width: 480px;
                height: 90vh;
                border-radius: 30px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            }
            body {
                padding: 20px;
            }
        }

        /* 顶部状态栏安全区域 */
        .safe-area-top {
            height: env(safe-area-inset-top, 20px);
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 20px;
            text-align: center;
            flex-shrink: 0;
        }

        header h1 {
            font-size: clamp(18px, 5vw, 28px);
            margin-bottom: 3px;
        }

        .subtitle {
            font-size: clamp(11px, 3vw, 14px);
            opacity: 0.9;
        }

        /* 虚拟人物区域 */
        .avatar-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 15px;
            background: #f8f9ff;
            border-bottom: 2px solid #e0e0ff;
            flex-shrink: 0;
        }

        .avatar-container {
            position: relative;
            width: clamp(80px, 20vw, 120px);
            height: clamp(80px, 20vw, 120px);
            margin-bottom: 8px;
        }

        .avatar {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s;
            cursor: pointer;
        }

        .avatar:active {
            transform: scale(0.95);
        }

        .avatar.speaking {
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .avatar-face {
            position: relative;
            width: 60%;
            height: 60%;
        }

        .eyes {
            display: flex;
            justify-content: space-around;
            position: absolute;
            top: 25%;
            width: 100%;
        }

        .eye {
            width: clamp(8px, 2.5vw, 12px);
            height: clamp(8px, 2.5vw, 12px);
            background: #333;
            border-radius: 50%;
            animation: blink 3s infinite;
        }

        @keyframes blink {
            0%, 90%, 100% { transform: scaleY(1); }
            95% { transform: scaleY(0.1); }
        }

        .mouth {
            position: absolute;
            bottom: 20%;
            left: 50%;
            transform: translateX(-50%);
            width: clamp(20px, 6vw, 30px);
            height: clamp(10px, 3vw, 15px);
            border-bottom: 3px solid #333;
            border-radius: 0 0 15px 15px;
            transition: all 0.3s;
        }

        .mouth.speaking {
            width: clamp(15px, 4vw, 20px);
            height: clamp(15px, 4vw, 20px);
            border-radius: 50%;
            animation: speak 0.3s infinite;
        }

        @keyframes speak {
            0%, 100% { transform: translateX(-50%) scale(1); }
            50% { transform: translateX(-50%) scale(0.8); }
        }

        .speaking-indicator {
            display: none;
            position: absolute;
            bottom: -25px;
            left: 50%;
            transform: translateX(-50%);
            gap: 4px;
        }

        .speaking-indicator.active {
            display: flex;
        }

        .speaking-indicator span {
            width: clamp(6px, 1.5vw, 8px);
            height: clamp(6px, 1.5vw, 8px);
            background: #667eea;
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out both;
        }

        .speaking-indicator span:nth-child(1) { animation-delay: -0.32s; }
        .speaking-indicator span:nth-child(2) { animation-delay: -0.16s; }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        .avatar-name {
            font-size: clamp(14px, 4vw, 18px);
            font-weight: bold;
            color: #667eea;
            margin-top: 8px;
        }

        /* 对话区域 */
        .chat-area {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-height: 200px;
            -webkit-overflow-scrolling: touch;
        }

        .message {
            display: flex;
            flex-direction: column;
            max-width: 85%;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.user {
            align-self: flex-end;
        }

        .message.ai {
            align-self: flex-start;
        }

        .message-bubble {
            padding: clamp(8px, 2vw, 12px) clamp(12px, 3vw, 18px);
            border-radius: clamp(16px, 4vw, 20px);
            position: relative;
            word-break: break-word;
        }

        .user .message-bubble {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-bottom-right-radius: 5px;
        }

        .ai .message-bubble {
            background: #f0f0f0;
            color: #333;
            border-bottom-left-radius: 5px;
        }

        .en-subtitle {
            font-size: clamp(13px, 3.5vw, 16px);
            margin-bottom: 3px;
        }

        .zh-subtitle {
            font-size: clamp(11px, 2.8vw, 13px);
            opacity: 0.7;
            font-style: italic;
        }

        .user .zh-subtitle {
            opacity: 0.8;
        }

        /* 纠正消息 */
        .correction {
            background: #fff3cd !important;
            border: 1px solid #ffc107;
            margin-top: 6px;
            padding: clamp(8px, 2vw, 10px);
            border-radius: 10px;
            font-size: clamp(11px, 2.8vw, 13px);
            max-width: 85%;
            align-self: flex-end;
        }

        .correction-label {
            color: #ff6b6b;
            font-weight: bold;
            font-size: clamp(10px, 2.5vw, 12px);
            margin-bottom: 4px;
        }

        .correction-content {
            color: #666;
        }

        .original {
            text-decoration: line-through;
            color: #ff6b6b;
        }

        .corrected {
            color: #28a745;
            font-weight: bold;
        }

        /* 输入区域 */
        .input-section {
            padding: clamp(10px, 2.5vw, 15px);
            background: white;
            border-top: 1px solid #e0e0e0;
            flex-shrink: 0;
            padding-bottom: env(safe-area-inset-bottom, 15px);
        }

        .input-container {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .voice-btn {
            width: clamp(38px, 10vw, 45px);
            height: clamp(38px, 10vw, 45px);
            border-radius: 50%;
            border: 2px solid #667eea;
            background: white;
            font-size: clamp(16px, 4vw, 20px);
            cursor: pointer;
            transition: all 0.3s;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .voice-btn:active {
            background: #667eea;
            transform: scale(0.95);
        }

        .voice-btn.recording {
            background: #ff4444;
            color: white;
            animation: pulse 1s infinite;
            border-color: #ff4444;
        }

        #userInput {
            flex: 1;
            padding: clamp(10px, 2.5vw, 12px) clamp(15px, 4vw, 20px);
            border: 2px solid #e0e0e0;
            border-radius: 25px;
            font-size: clamp(14px, 3.5vw, 16px);
            outline: none;
            transition: border-color 0.3s;
            -webkit-user-select: text;
            user-select: text;
        }

        #userInput:focus {
            border-color: #667eea;
        }

        .send-btn {
            padding: clamp(10px, 2.5vw, 12px) clamp(18px, 5vw, 25px);
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 25px;
            font-size: clamp(14px, 3.5vw, 16px);
            cursor: pointer;
            transition: transform 0.2s;
            flex-shrink: 0;
            font-weight: bold;
        }

        .send-btn:active {
            transform: scale(0.95);
        }

        /* 建议按钮 */
        .suggestions {
            display: flex;
            gap: 6px;
            margin-top: 8px;
            flex-wrap: wrap;
            align-items: center;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .suggestion-label {
            font-size: clamp(10px, 2.5vw, 12px);
            color: #999;
            flex-shrink: 0;
        }

        .suggestion-btn {
            padding: 5px 12px;
            background: #f0f0f0;
            border: 1px solid #ddd;
            border-radius: 15px;
            font-size: clamp(10px, 2.5vw, 12px);
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .suggestion-btn:active {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

        /* 滚动条样式 */
        .chat-area::-webkit-scrollbar {
            width: 4px;
        }

        .chat-area::-webkit-scrollbar-track {
            background: transparent;
        }

        .chat-area::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 2px;
        }

        /* Toast提示 */
        .toast {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-size: 14px;
            z-index: 1000;
            animation: fadeInOut 2s ease;
        }

        @keyframes fadeInOut {
            0%, 100% { opacity: 0; }
            10%, 90% { opacity: 1; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="safe-area-top"></div>
        
        <!-- 顶部标题栏 -->
        <header>
            <h1>🤖 AI 英語導師</h1>
            <p class="subtitle">同你一齊練習英文對話</p>
        </header>

        <!-- 虚拟人物区域 -->
        <div class="avatar-section">
            <div class="avatar-container">
                <div class="avatar" id="avatar">
                    <div class="avatar-face">
                        <div class="eyes">
                            <div class="eye left-eye"></div>
                            <div class="eye right-eye"></div>
                        </div>
                        <div class="mouth" id="mouth"></div>
                    </div>
                </div>
                <div class="speaking-indicator" id="speakingIndicator">
                    <span></span><span></span><span></span>
                </div>
            </div>
            <div class="avatar-name">Teacher Emma 👩‍🏫</div>
        </div>

        <!-- 对话区域 -->
        <div class="chat-area" id="chatArea"></div>

        <!-- 输入区域 -->
        <div class="input-section">
            <div class="input-container">
                <button class="voice-btn" id="voiceBtn" title="語音輸入">🎤</button>
                <input 
                    type="text" 
                    id="userInput" 
                    placeholder="輸入英文... (Enter 發送)"
                    autocomplete="off"
                />
                <button class="send-btn" id="sendBtn">發送</button>
            </div>
            <div class="suggestions" id="suggestions">
                <span class="suggestion-label">💡</span>
                <button class="suggestion-btn">Tell me about your hobbies</button>
                <button class="suggestion-btn">How are you today?</button>
                <button class="suggestion-btn">What's your name?</button>
            </div>
        </div>
    </div>

    <script>
        // 注册 Service Worker (用于PWA)
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('data:application/javascript,' + encodeURIComponent(`
                    self.addEventListener('install', e => self.skipWaiting());
                    self.addEventListener('activate', e => self.clients.claim());
                    self.addEventListener('fetch', e => {
                        e.respondWith(
                            caches.match(e.request).then(r => r || fetch(e.request))
                        );
                    });
                `)).catch(() => {});
            });
        }

        // AI对话数据库
        const conversationDB = {
            greetings: [
                "Hello! How are you today?",
                "Hi there! Nice to meet you!",
                "Good morning! How's it going?"
            ],
            responses: {
                "how are you": "I'm doing great, thank you for asking! How about you?",
                "i'm fine": "That's wonderful to hear! Let's continue our English practice.",
                "what's your name": "My name is Emma. I'm your English tutor. What's your name?",
                "my name is": "Nice to meet you! That's a beautiful name. Where are you from?",
                "where are you from": "I'm from London, England. Have you ever been there?",
                "hobbies": "I love reading books and playing the piano. What do you like to do in your free time?",
                "i like": "Oh, that's interesting! Can you tell me more about why you like it?",
                "i love": "Really? That's great! How often do you do that?",
                "weather": "It's a beautiful sunny day today! Perfect for learning English, don't you think?",
                "food": "I enjoy Italian food, especially pasta. What's your favorite cuisine?",
                "movie": "I recently watched a great movie! Do you enjoy watching films?",
                "music": "Music is wonderful! I enjoy classical and pop music. What kind of music do you like?",
                "travel": "Traveling is amazing! I've been to many countries. Where would you like to visit?",
                "thank you": "You're very welcome! Keep up the good work with your English!",
                "bye": "Goodbye! It was nice talking to you. Come back soon to practice more!",
                "good morning": "Good morning! You sound energetic today. Ready to practice English?",
                "good night": "Good night! Sweet dreams. Remember to practice English tomorrow too!",
                "sorry": "No need to apologize! Making mistakes is part of learning. Let's try again."
            }
        };

        // 语法纠正数据库
        const grammarCorrections = {
            patterns: [
                {
                    regex: /\b(i)\b(?!['\w])/g,
                    correction: 'I',
                    description: '"i" 應該大寫為 "I"'
                },
                {
                    regex: /\b((?:he|she|it|this|that|everyone|everybody|nobody|someone|somebody|anyone|anybody)\s+(do|have))\b/gi,
                    correctionFunc: (match) => {
                        const words = match.split(' ');
                        if (words[1] === 'do') words[1] = 'does';
                        if (words[1] === 'have') words[1] = 'has';
                        return words.join(' ');
                    },
                    description: '第三人稱單數動詞需要變化'
                },
                {
                    regex: /\b(goed)\b/gi,
                    correction: 'went',
                    description: '"go" 的過去式是 "went"，不是 "goed"'
                },
                {
                    regex: /\b(more\s+(better|bigger|faster|stronger|smarter))\b/gi,
                    correctionFunc: (match) => match.replace('more ', ''),
                    description: '比較級不需要加 "more"'
                },
                {
                    regex: /\b(i\s+is)\b/gi,
                    correction: 'I am',
                    description: '"I" 後面要用 "am"，不是 "is"'
                },
                {
                    regex: /\b(you\s+is)\b/gi,
                    correction: 'you are',
                    description: '"you" 後面要用 "are"'
                },
                {
                    regex: /\b(he\s+am|she\s+am|it\s+am)\b/gi,
                    correctionFunc: (match) => match.replace('am', 'is'),
                    description: '第三人稱單數用 "is"'
                },
                {
                    regex: /\b(don't\s+like[s]?)\b.*\b(it|this|that)\b/gi,
                    correctionFunc: (match) => match,
                    description: '檢查否定句結構'
                }
            ]
        };

        class EnglishTutor {
            constructor() {
                this.chatArea = document.getElementById('chatArea');
                this.userInput = document.getElementById('userInput');
                this.sendBtn = document.getElementById('sendBtn');
                this.voiceBtn = document.getElementById('voiceBtn');
                this.avatar = document.getElementById('avatar');
                this.mouth = document.getElementById('mouth');
                this.speakingIndicator = document.getElementById('speakingIndicator');
                
                this.isRecording = false;
                this.recognition = null;
                this.isSpeaking = false;
                
                this.init();
            }
            
            init() {
            
